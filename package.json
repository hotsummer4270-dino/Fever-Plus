{
  "name": "fever-plus",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "build:pages": "VITE_CLOUD_SYNC_ENABLED=true vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "d1:migrate:local": "wrangler d1 migrations apply fever-plus-local --local",
    "pages:dev": "wrangler pages dev dist --port 8788",
    "test:api": "node scripts/api-smoke.mjs"
  },
  "dependencies": {
    "@cloudflare/pages-plugin-cloudflare-access": "^1.0.5",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260710.1",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
